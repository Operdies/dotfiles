#! /bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &

# load appropriate monitor config 
if xrandr | grep "^DP1 connected"; then
  # Load monitor layout if display port 1 is connected
  ~/.screenlayout/monitor.sh
  bspc monitor DP1 -d 1 2 3 4 5 6 7 8 9
  bspc monitor eDP1 -a 0
else
  # Otherwise, only use the laptop monitor (eDP1)
  ~/.screenlayout/laptop.sh
  bspc monitor -d 1 2 3 4 5 6 7 8 9 0
fi

bspc config split_ratio          0.65
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config pointer_follows_focus true
bspc config focus_follows_pointer false

# prevent windows from stealing focus
bspc config ignore_ewmh_focus true

bspc config window_gap 20
# Border
bspc config border_width 2
bspc config focused_border_color        "#ac21c4"
bspc config normal_border_color         "#073642"
bspc config active_border_color         "#073642"

# Put teams on the last desktop
bspc rule -a teams-for-linux desktop=^10

# Bar
~/.config/polybar/launch.sh &
# Notifications
/usr/bin/dunst &
# Polkit
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
# Wallpaper
nitrogen --restore &
# Dex
dex -a -s /etc/xdg/autostart/:~/.config/autostart/  

# the firewall-applet in /etc/xdg/autostart/firewall-applet.desktop
# does not check if it is already running and will launch new instances.
# This hack just kills them all and starts a new one
pkill firewall-applet 
firewall-applet &
# Network Applet
nm-applet --indicator &

# Cursor
xsetroot -cursor_name left_ptr &

# Low battery notifier
# ~/.config/bspwm/scripts/low_bat_notifier.sh

# Set caps = escape
setxkbmap -option caps:escape
# Set keymap
setxkbmap us altgr-intl

pgrep -x xautolock > /dev/null || xautolock -time 5 -locker "/home/alex/.config/bspwm/scripts/i3lock-fancy/i3lock-fancy.sh" -detectsleep &

# disable screen sleeping on inactivity
xset -dpms &
xset s off &

# picom
# -b: daemon mode
picom -b --config ~/.config/picom.conf

# Enable natural scrolling
xinput set-prop 14 316 1

# Rebind \| next to 'z' to `~
xmodmap -e 'keycode 94 = grave asciitilde'
